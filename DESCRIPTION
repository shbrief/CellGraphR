Package: CellGraphR
Title: Graph Analysis for Histopathology Images
Version: 0.99.0
Date: 2026-02-27
Authors@R: person("Sehyun", "Oh", role = c("aut", "cre"),
    email = "shbrief@gmail.com")
Description: Import, compute, and analyse cell-level spatial graphs derived
    from whole-slide histopathology images. Provides functions to read
    pre-computed PyTables HDF5 graph files into igraph objects, extract
    graph-derived spatial features (topology, mixing, Moran's I, Voronoi,
    immune metrics, etc.), store them as SummarizedExperiment, integrate with
    a MultiAssayExperiment, and test associations with clinical or MOFA factor
    outcomes.
License: Artistic-2.0
Depends:
    R (>= 4.4.0)
Imports:
    igraph,
    reticulate,
    SummarizedExperiment,
    MultiAssayExperiment,
    S4Vectors,
    spatstat.geom,
    spatstat.explore,
    sf,
    stats,
    utils,
    ggplot2
Suggests:
    MOFA2,
    curatedTCGAData,
    survival,
